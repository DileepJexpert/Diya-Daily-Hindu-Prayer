# Optional: load the prayer catalog from a server instead of the bundled copy.
# When unset (the default), the app uses its built-in content and works offline.
#
# Local web demo — public/catalog.json is served at /catalog.json:
#   1. npm run content:export      # writes public/catalog.json
#   2. cp .env.example .env
#   3. npx expo start --web        # then edit public/catalog.json and reload
EXPO_PUBLIC_CONTENT_URL=/catalog.json
#
# Production (native + web): point to an absolute CMS/CDN URL, e.g.
# EXPO_PUBLIC_CONTENT_URL=https://cdn.example.com/diya/catalog.json

# RevenueCat (only needed once you re-enable paid membership)
# EXPO_PUBLIC_REVENUECAT_KEY=
