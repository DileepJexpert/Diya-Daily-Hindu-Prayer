# ── Quick audio test ─────────────────────────────────────────────────────────
# Hear your OWN audio (a Suno export, a Creative-Commons recitation, an MP3 you
# have rights to) on the Gayatri Mantra — with the words highlighting in sync.
# Paste a direct MP3 URL, run `cp .env.example .env`, restart `npx expo start`,
# then open Gayatri Mantra and press play.
# EXPO_PUBLIC_TEST_AUDIO_URL=https://example.com/your-gayatri.mp3

# Optional: load the prayer catalog from a server instead of the bundled copy.
# When unset (the default), the app uses its built-in content and works offline.
#
# Local web demo — public/catalog.json is served at /catalog.json:
#   1. npm run content:export      # writes public/catalog.json
#   2. cp .env.example .env
#   3. npx expo start --web        # then edit public/catalog.json and reload
EXPO_PUBLIC_CONTENT_URL=/catalog.json
#
# On your PHONE (Expo Go) or production: use an absolute URL. The repo already
# hosts the catalog on GitHub, so this works today:
# EXPO_PUBLIC_CONTENT_URL=https://raw.githubusercontent.com/DileepJexpert/Diya-Daily-Hindu-Prayer/main/public/catalog.json
# (For production, host the JSON on your own CMS/CDN instead.)

# RevenueCat (only needed once you re-enable paid membership)
# EXPO_PUBLIC_REVENUECAT_KEY=

# ── Creator Studio (in-app admin) ────────────────────────────────────────────
# Publish your own bhajans (e.g. a Suno export) from More → Creator Studio.
#
# MOCK (default): published tracks are saved on this device and appear instantly.
# A passcode gates the screen (default 1008):
# EXPO_PUBLIC_STUDIO_PASSCODE=1008
#
# SUPABASE (real): stores the audio on your bucket and publishes the track list
# so EVERY user sees it. Full setup — bucket, policies, admin user —
# in docs/CREATOR_STUDIO_SUPABASE.md. Then set:
# EXPO_PUBLIC_STUDIO_BACKEND=supabase
# EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
# EXPO_PUBLIC_STUDIO_BUCKET=studio
#
# In supabase mode the Studio asks for your admin email + password (the user you
# created in Supabase Auth) instead of the passcode.
